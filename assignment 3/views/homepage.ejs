<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daraz Clone</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="top-orange-bar">
        <div class="container">
            <div class="top-links">
                <span>Become a Seller</span>
                <span>Help & Support</span>
                <% if (currentUser) { %>
                    <a href="/checkout" style="color: white; text-decoration: none;">Checkout</a>
                    <span>My Profile (<%= currentUser.name %>)</span>
                    <a href="/logout" style="color: white; text-decoration: none;">Logout</a>
                    <% if (currentUser.role === 'admin') { %>
                        <a href="/admin" style="color: white; text-decoration: none; font-weight: bold;">Admin Panel</a>
                    <% } %>
                <% } else { %>
                    <a href="/login" style="color: white; text-decoration: none;">Login</a>
                    <a href="/register" style="color: white; text-decoration: none;">Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>

    <div class="container" style="margin-top: 10px;">
        <% if (error && error.length > 0) { %>
            <div style="color: #d32f2f; background-color: #fde0dc; padding: 10px; border-radius: 4px; margin-bottom: 10px;"><%= error %></div>
        <% } %>
        <% if (success && success.length > 0) { %>
            <div style="color: #388e3c; background-color: #e8f5e9; padding: 10px; border-radius: 4px; margin-bottom: 10px;"><%= success %></div>
        <% } %>
    </div>

    <header class="main-header">
        <div class="container navbar">
            <div class="logo">Daraz</div>
            <div class="search-box" style="flex: 1; margin: 0 20px;">
                <form action="" method="GET" style="display: flex; gap: 10px; width: 100%;">
                    <input type="text" name="search" placeholder="Search in Daraz" value="<%= search %>" style="flex: 2;">
                    <select name="category" style="padding: 10px; border-radius: 4px; border: none; outline: none;">
                        <option value="All" <%= category === 'All' ? 'selected' : '' %>>All Categories</option>
                        <option value="Electronics" <%= category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                        <option value="Fashion" <%= category === 'Fashion' ? 'selected' : '' %>>Fashion</option>
                        <option value="Home" <%= category === 'Home' ? 'selected' : '' %>>Home</option>
                    </select>
                    <input type="number" name="minPrice" placeholder="Min Rs" value="<%= minPrice %>" style="width: 80px; padding: 10px; border-radius: 4px; border: none; outline: none;">
                    <input type="number" name="maxPrice" placeholder="Max Rs" value="<%= maxPrice %>" style="width: 80px; padding: 10px; border-radius: 4px; border: none; outline: none;">
                    <button type="submit" style="background: #f85606; color: white; border: none; padding: 10px 20px; cursor: pointer;">Search</button>
                </form>
            </div>
            <div class="cart-container">
                <div class="cart-icon-css"></div>
                <span class="cart-text">Cart</span>
            </div>
        </div>
    </header>

    <nav class="category-nav">
        <div class="container">
            <button class="nav-toggle" onclick="this.nextElementSibling.classList.toggle('open')">☰ Categories</button>
            <ul class="nav-links">
                <li><a href="#">Flash Deals</a></li>
                <li><a href="#">Mobiles & Tablets</a></li>
                <li><a href="#">Fashion</a></li>
                <li><a href="#">Electronics</a></li>
                <li><a href="#">Home & Living</a></li>
                <li><a href="#">Health & Beauty</a></li>
                <li><a href="#">Sports & Travel</a></li>
                <li><a href="#">Groceries</a></li>
                <li><a href="#" class="nav-sale">⚡ Super Sale</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <section class="banners">
            <img src="/Mega Deals.avif" alt="Mega Deals" class="hero-img">
            <img src="/Summer sale.webp" alt="Summer Sale" class="hero-img">
        </section>

        <h2 class="section-title">Just For You</h2>
        <div class="product-grid">
            <% if (products.length === 0) { %>
                <p>No products found matching your filters.</p>
            <% } else { %>
                <% products.forEach(product => { %>
                <div class="card">
                    <img src="<%= product.imageUrl %>" alt="<%= product.name %>">
                    <div class="card-info">
                        <p class="name"><%= product.name %></p>
                        <p class="price">Rs. <%= product.price %></p>
                        <p style="font-size: 12px; color: #777;"><%= product.category %> | ★ <%= product.rating %></p>
                    </div>
                </div>
                <% }) %>
            <% } %>
        </div>

        <!-- Pagination Controls -->
        <% if (totalPages > 1) { %>
        <div style="display: flex; justify-content: center; gap: 10px; margin-top: 30px; margin-bottom: 30px;">
            <% if (currentPage > 1) { %>
                <a href="?page=<%= currentPage - 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" style="padding: 10px 15px; background: #ddd; color: #333; text-decoration: none; border-radius: 4px;">Previous</a>
            <% } %>
            
            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" style="padding: 10px 15px; background: <%= currentPage === i ? '#f85606' : '#ddd' %>; color: <%= currentPage === i ? 'white' : '#333' %>; text-decoration: none; border-radius: 4px;"><%= i %></a>
            <% } %>

            <% if (currentPage < totalPages) { %>
                <a href="?page=<%= currentPage + 1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" style="padding: 10px 15px; background: #ddd; color: #333; text-decoration: none; border-radius: 4px;">Next</a>
            <% } %>
        </div>
        <% } %>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-links">
                <span>Customer Care</span> | 
                <span>Contact Us</span> | 
                <span>Terms & Conditions</span> | 
                <span>Privacy Policy</span>
            </div>
            <p>&copy; 2026 Daraz Online Shopping</p>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>