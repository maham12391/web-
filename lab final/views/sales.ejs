<main class="container" style="margin-top: 30px; margin-bottom: 50px;">
    <div class="dashboard-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
        <div>
            <h1 style="font-size: 28px; font-weight: bold; color: #212121; margin: 0;">📊 Sales & Revenue Dashboard</h1>
            <p style="color: #757575; margin: 5px 0 0 0;">Real-time view of your store's sales metrics and recent orders.</p>
        </div>
        <div class="live-status-container" style="display: flex; align-items: center; background: #e8f5e9; border: 1px solid #c8e6c9; padding: 8px 16px; border-radius: 20px;">
            <div class="pulsing-dot" style="width: 10px; height: 10px; background-color: #4caf50; border-radius: 50%; margin-right: 8px; box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7); animation: pulse 1.5s infinite;"></div>
            <span style="font-size: 13px; font-weight: 600; color: #2e7d32; margin-right: 12px;">Live Updates Active</span>
            <span id="countdown" style="font-size: 11px; color: #4caf50; font-family: monospace; font-weight: bold; background: white; padding: 2px 6px; border-radius: 10px; min-width: 32px; text-align: center; border: 1px solid #a5d6a7;">10s</span>
        </div>
    </div>

    <!-- Styles for Dashboard -->
    <style>
        @keyframes pulse {
            0% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(76, 175, 80, 0.7);
            }
            70% {
                transform: scale(1);
                box-shadow: 0 0 0 8px rgba(76, 175, 80, 0);
            }
            100% {
                transform: scale(0.95);
                box-shadow: 0 0 0 0 rgba(76, 175, 80, 0);
            }
        }

        .metric-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .metric-card {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #eeeeee;
            transition: transform 0.2s, box-shadow 0.2s, background-color 0.4s;
            position: relative;
            overflow: hidden;
        }

        .metric-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.06);
        }

        .metric-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }

        .card-revenue::before { background-color: #2196f3; }
        .card-orders::before { background-color: #ff9800; }
        .card-top-product::before { background-color: #e91e63; }

        .metric-title {
            font-size: 14px;
            color: #757575;
            text-transform: uppercase;
            font-weight: bold;
            letter-spacing: 0.5px;
            margin-bottom: 10px;
        }

        .metric-value {
            font-size: 32px;
            font-weight: 800;
            color: #212121;
            margin: 0;
            font-family: 'Outfit', 'Inter', -apple-system, sans-serif;
        }

        .metric-sub {
            margin-top: 8px;
            font-size: 13px;
            color: #9e9e9e;
        }

        .flash-update {
            background-color: #fff9c4 !important; /* Soft yellow highlight */
            transition: none !important;
        }

        /* Table Styles */
        .dashboard-section {
            background: white;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.03);
            border: 1px solid #eeeeee;
        }

        .section-title {
            font-size: 18px;
            font-weight: bold;
            color: #212121;
            margin-top: 0;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .recent-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }

        .recent-table th {
            padding: 14px 16px;
            font-size: 13px;
            color: #757575;
            text-transform: uppercase;
            font-weight: bold;
            border-bottom: 2px solid #eeeeee;
        }

        .recent-table td {
            padding: 16px;
            font-size: 14px;
            color: #212121;
            border-bottom: 1px solid #f5f5f5;
        }

        .recent-table tr:last-child td {
            border-bottom: none;
        }

        .recent-table tr {
            transition: background-color 0.2s;
        }

        .recent-table tr:hover {
            background-color: #fafafa;
        }

        /* Status Badges */
        .status-badge {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .status-pending { background-color: #fff3e0; color: #fb8c00; }
        .status-processing { background-color: #e3f2fd; color: #1e88e5; }
        .status-shipped { background-color: #f3e5f5; color: #8e24aa; }
        .status-delivered { background-color: #e8f5e9; color: #43a047; }
    </style>

    <!-- Metric Cards Grid -->
    <div class="metric-grid">
        <!-- Revenue Card -->
        <div class="metric-card card-revenue" id="revenue-card">
            <div class="metric-title">Total Revenue</div>
            <div class="metric-value" id="revenue-value">Rs. <%= totalRevenue.toLocaleString() %></div>
            <div class="metric-sub">Calculated from all completed/placed orders</div>
        </div>

        <!-- Orders Card -->
        <div class="metric-card card-orders" id="orders-card">
            <div class="metric-title">Total Orders</div>
            <div class="metric-value" id="orders-value"><%= totalOrders %></div>
            <div class="metric-sub">Total transaction count in system</div>
        </div>

        <!-- Top Product Card -->
        <div class="metric-card card-top-product" id="top-product-card">
            <div class="metric-title">Top-Selling Product</div>
            <div class="metric-value" id="top-product-value" style="font-size: 22px; padding-top: 8px; line-height: 1.2;">
                <%= topProduct ? topProduct.name : 'N/A' %>
            </div>
            <div class="metric-sub" id="top-product-sub">
                <% if (topProduct) { %>
                    <strong><%= topProduct.quantity %></strong> units sold (Rs. <%= topProduct.price.toLocaleString() %> each)
                <% } else { %>
                    No sales recorded yet
                <% } %>
            </div>
        </div>
    </div>

    <!-- Recent Orders Table Section -->
    <div class="dashboard-section">
        <div class="section-title">
            <span>Recent Transactions</span>
            <span style="font-size: 12px; font-weight: normal; color: #9e9e9e;">Showing last 5 orders</span>
        </div>
        <div style="overflow-x: auto;">
            <table class="recent-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Products</th>
                        <th>Total Amount</th>
                        <th>Status</th>
                        <th>Date & Time</th>
                    </tr>
                </thead>
                <tbody id="orders-table-body">
                    <% if (recentOrders && recentOrders.length > 0) { %>
                        <% recentOrders.forEach(order => { %>
                            <tr id="order-row-<%= order._id %>">
                                <td style="font-family: monospace; font-weight: bold; color: #616161;">#<%= order._id.toString().slice(-4).toUpperCase() %></td>
                                <td>
                                    <div style="font-weight: 600;"><%= order.user ? order.user.name : 'Guest' %></div>
                                    <div style="font-size: 12px; color: #757575;"><%= order.user ? order.user.email : '' %></div>
                                </td>
                                <td>
                                    <ul style="margin: 0; padding-left: 16px; font-size: 13px;">
                                        <% order.products.forEach(p => { %>
                                            <li><%= p.product ? p.product.name : 'Unknown Product' %> (x<%= p.quantity %>)</li>
                                        <% }) %>
                                    </ul>
                                </td>
                                <td style="font-weight: bold; color: #e91e63;">Rs. <%= order.totalAmount.toLocaleString() %></td>
                                <td>
                                    <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
                                </td>
                                <td style="font-size: 13px; color: #757575;">
                                    <%= new Date(order.createdAt).toLocaleString() %>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="6" style="text-align: center; color: #9e9e9e; padding: 30px;">No recent orders found.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</main>

<script>
    $(document).ready(function() {
        // Keep track of current metrics to detect changes
        let currentRevenueText = $('#revenue-value').text();
        let currentOrdersText = $('#orders-value').text();
        let currentTopProductText = $('#top-product-value').text();

        // 10-second polling interval variables
        let pollInterval = 10000; // 10 seconds
        let countdown = 10;

        // Timer to update countdown display
        setInterval(function() {
            countdown--;
            if (countdown <= 0) {
                countdown = 10;
            }
            $('#countdown').text(countdown + 's');
        }, 1000);

        // Function to flash animate card background on change
        function flashCard(cardId) {
            const $card = $('#' + cardId);
            $card.addClass('flash-update');
            setTimeout(function() {
                $card.removeClass('flash-update');
            }, 500);
        }

        // Periodic AJAX call to get latest statistics
        setInterval(function() {
            $.getJSON('/api/sales-data')
                .done(function(data) {
                    if (data.success) {
                        // 1. Update Revenue
                        const newRevenueText = 'Rs. ' + data.totalRevenue.toLocaleString();
                        if (newRevenueText !== currentRevenueText) {
                            $('#revenue-value').text(newRevenueText);
                            flashCard('revenue-card');
                            currentRevenueText = newRevenueText;
                        }

                        // 2. Update Orders
                        const newOrdersText = data.totalOrders.toString();
                        if (newOrdersText !== currentOrdersText) {
                            $('#orders-value').text(newOrdersText);
                            flashCard('orders-card');
                            currentOrdersText = newOrdersText;
                        }

                        // 3. Update Top-Selling Product
                        const newTopProductText = data.topProduct ? data.topProduct.name : 'N/A';
                        if (newTopProductText !== currentTopProductText) {
                            $('#top-product-value').text(newTopProductText);
                            if (data.topProduct) {
                                $('#top-product-sub').html(
                                    '<strong>' + data.topProduct.quantity + '</strong> units sold (Rs. ' + data.topProduct.price.toLocaleString() + ' each)'
                                );
                            } else {
                                $('#top-product-sub').text('No sales recorded yet');
                            }
                            flashCard('top-product-card');
                            currentTopProductText = newTopProductText;
                        }

                        // 4. Update Recent Orders Table
                        const $tbody = $('#orders-table-body');
                        if (data.recentOrders && data.recentOrders.length > 0) {
                            let rowsHtml = '';
                            data.recentOrders.forEach(order => {
                                let customerName = order.user ? order.user.name : 'Guest';
                                let customerEmail = order.user ? order.user.email : '';
                                
                                let productsList = '<ul style="margin: 0; padding-left: 16px; font-size: 13px;">';
                                order.products.forEach(p => {
                                    let pName = p.product ? p.product.name : 'Unknown Product';
                                    productsList += '<li>' + pName + ' (x' + p.quantity + ')</li>';
                                });
                                productsList += '</ul>';

                                let orderDate = new Date(order.createdAt).toLocaleString();
                                
                                rowsHtml += '<tr id="order-row-' + order._id + '">' +
                                    '<td style="font-family: monospace; font-weight: bold; color: #616161;">#' + order._id.slice(-4).toUpperCase() + '</td>' +
                                    '<td>' +
                                        '<div style="font-weight: 600;">' + customerName + '</div>' +
                                        '<div style="font-size: 12px; color: #757575;">' + customerEmail + '</div>' +
                                    '</td>' +
                                    '<td>' + productsList + '</td>' +
                                    '<td style="font-weight: bold; color: #e91e63;">Rs. ' + order.totalAmount.toLocaleString() + '</td>' +
                                    '<td>' +
                                        '<span class="status-badge status-' + order.status + '">' + order.status + '</span>' +
                                    '</td>' +
                                    '<td style="font-size: 13px; color: #757575;">' + orderDate + '</td>' +
                                '</tr>';
                            });
                            
                            // Check if table body content actually changed before replacing to prevent layout flickers
                            const tempDiv = $('<div>').html(rowsHtml);
                            if ($tbody.html() !== tempDiv.html()) {
                                $tbody.html(rowsHtml);
                            }
                        } else {
                            $tbody.html('<tr><td colspan="6" style="text-align: center; color: #9e9e9e; padding: 30px;">No recent orders found.</td></tr>');
                        }
                    }
                })
                .fail(function(err) {
                    console.error('Error fetching sales data:', err);
                });
        }, pollInterval);
    });
</script>
