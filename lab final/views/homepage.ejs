<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daraz Clone</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="top-orange-bar">
        <div class="container">
            <div class="top-links">
                <span>Become a Seller</span>
                <span>Help & Support</span>
                <% if (currentUser) { %>
                    <a href="/checkout" style="color: white; text-decoration: none;">Checkout</a>
                    <span>My Profile (<%= currentUser.name %>)</span>
                    <a href="/logout" style="color: white; text-decoration: none;">Logout</a>
                    <% if (currentUser.role === 'admin') { %>
                        <a href="/admin" style="color: white; text-decoration: none; font-weight: bold;">Admin Panel</a>
                        <a href="/sales" style="color: white; text-decoration: none; font-weight: bold; margin-left: 10px;">Sales Dashboard</a>
                    <% } %>
                <% } else { %>
                    <a href="/login" style="color: white; text-decoration: none;">Login</a>
                    <a href="/register" style="color: white; text-decoration: none;">Sign Up</a>
                <% } %>
            </div>
        </div>
    </div>

    <div class="container" style="margin-top: 10px;">
        <% if (error && error.length > 0) { %>
            <div style="color: #d32f2f; background-color: #fde0dc; padding: 10px; border-radius: 4px; margin-bottom: 10px;"><%= error %></div>
        <% } %>
        <% if (success && success.length > 0) { %>
            <div style="color: #388e3c; background-color: #e8f5e9; padding: 10px; border-radius: 4px; margin-bottom: 10px;"><%= success %></div>
        <% } %>
    </div>

    <header class="main-header">
        <div class="container navbar">
            <div class="logo">Daraz</div>
            <div class="search-box">
                <input type="text" placeholder="Search in Daraz">
                <button>Search</button>
            </div>
            <div class="cart-container">
                <div class="cart-icon-css"></div>
                <span class="cart-text">Cart</span>
            </div>
        </div>
    </header>

    <nav class="category-nav">
        <div class="container">
            <button class="nav-toggle" onclick="this.nextElementSibling.classList.toggle('open')">☰ Categories</button>
            <ul class="nav-links">
                <li><a href="#">Flash Deals</a></li>
                <li><a href="#">Mobiles & Tablets</a></li>
                <li><a href="#">Fashion</a></li>
                <li><a href="#">Electronics</a></li>
                <li><a href="#">Home & Living</a></li>
                <li><a href="#">Health & Beauty</a></li>
                <li><a href="#">Sports & Travel</a></li>
                <li><a href="#">Groceries</a></li>
                <li><a href="#" class="nav-sale">⚡ Super Sale</a></li>
            </ul>
        </div>
    </nav>

    <main class="container">
        <section class="banners">
            <img src="/Mega Deals.avif" alt="Mega Deals" class="hero-img">
            <img src="/Summer sale.webp" alt="Summer Sale" class="hero-img">
        </section>

        <h2 class="section-title">Just For You</h2>
        <div class="product-grid">
            
            <div class="card">
                <img src="/Shoes.avif" alt="Casual Sneakers">
                <div class="card-info">
                    <p class="name">Casual Sneakers</p>
                    <p class="price">Rs. 1,450</p>
                </div>
            </div>

            <div class="card">
                <img src="/T shirt.avif" alt="Cotton T-Shirt">
                <div class="card-info">
                    <p class="name">Cotton T-Shirt</p>
                    <p class="price">Rs. 750</p>
                </div>
            </div>

            <div class="card">
                <img src="/Shampoo.avif" alt="LOREAL Shampoo">
                <div class="card-info">
                    <p class="name">LOREAL Shampoo</p>
                    <p class="price">Rs. 850</p>
                </div>
            </div>

            <div class="card">
                <img src="/Hair Straightener.avif" alt="Hair Straightener">
                <div class="card-info">
                    <p class="name">Hair Straightener</p>
                    <p class="price">Rs. 1,800</p>
                </div>
            </div>

            <div class="card">
                <img src="/Slippers.avif" alt="Home Slippers">
                <div class="card-info">
                    <p class="name">Home Slippers</p>
                    <p class="price">Rs. 399</p>
                </div>
            </div>

            <div class="card">
                <img src="/Perfume.avif" alt="Men's Perfume">
                <div class="card-info">
                    <p class="name">Men's Perfume</p>
                    <p class="price">Rs. 3,200</p>
                </div>
            </div>

            <div class="card">
                <img src="/Star Clips.jpg_.avif" alt="Golden Star Hair Clips">
                <div class="card-info">
                    <p class="name">Golden Star Hair Clips</p>
                    <p class="price">Rs. 150</p>
                </div>
            </div>

            <div class="card">
                <img src="/Trending heels.avif" alt="Trending Summer Heels">
                <div class="card-info">
                    <p class="name">Trending Summer Heels</p>
                    <p class="price">Rs. 2,100</p>
                </div>
            </div>

            <div class="card">
                <img src="/Shampo2.avif" alt="Dove Shampoo">
                <div class="card-info">
                    <p class="name">Dove Shampoo</p>
                    <p class="price">Rs. 650</p>
                </div>
            </div>

        </div>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-links">
                <span>Customer Care</span> | 
                <span>Contact Us</span> | 
                <span>Terms & Conditions</span> | 
                <span>Privacy Policy</span>
            </div>
            <p>&copy; 2026 Daraz Online Shopping</p>
        </div>
    </footer>

    <script src="/js/script.js"></script>
</body>
</html>